---
// Lenis smooth scroll — activates on client:idle (when browser is free)
---

<script>
  import Lenis from 'lenis';

  let lenis: import("lenis").default | null = null;

  function initLenis() {
    if (lenis) return;

    lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      smoothWheel: true,
      wheelMultiplier: 0.8,
      touchMultiplier: 1.5,
    });

    function raf(time: number) {
      lenis!.raf(time);
      requestAnimationFrame(raf);
    }

    requestAnimationFrame(raf);

    // Connect with GSAP if available
    if (window.gsap && lenis) {
      import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
        lenis!.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis!.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
      });
    }
  }

  // Start Lenis when browser is idle
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initLenis);
  } else {
    setTimeout(initLenis, 500);
  }
</script>

<slot />
