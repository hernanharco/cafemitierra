---
export interface Props {
  business: any;
}

const { business } = Astro.props;

import StarRating from '../ui/StarRating.astro';
import ScrollReveal from '../effects/ScrollReveal.astro';

const visibleReviews = business.reviews.filter((r) => r.visible !== false);
---

<section class="py-24 px-6 bg-cream">
  <div class="max-w-4xl mx-auto">
    <ScrollReveal>
      <div class="text-center mb-12">
        <span class="inline-block text-rojo font-semibold text-sm tracking-widest uppercase mb-4">
          Reseñas
        </span>
        <h2 class="text-4xl md:text-5xl font-bold text-marron mb-4">
          Lo que dicen nuestros clientes
        </h2>
      </div>
    </ScrollReveal>

    <ScrollReveal delay={0.1}>
      <div class="bg-white rounded-2xl p-8 shadow-lg shadow-rojo/5 text-center mb-8">
        <div class="flex items-center justify-center gap-4 mb-4">
          <span class="text-5xl font-bold text-marron">{business.rating}</span>
          <div>
            <StarRating rating={business.rating} size="lg" />
            <p class="text-marron/50 text-sm mt-1">
              {business.reviews_count} reseñas en Google Maps
            </p>
          </div>
        </div>
        <a
          href={business.google_maps_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-rojo hover:text-rojo-dark font-medium transition-colors mt-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
          </svg>
          Ver en Google Maps
        </a>
      </div>
    </ScrollReveal>

    <!-- Reviews cards -->
    <div class="space-y-4" id="reviews-list">
      {visibleReviews.map((review, i) => (
        <ScrollReveal delay={0.2 + i * 0.1}>
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-rojo/20 flex items-center justify-center text-rojo font-bold text-lg">
                  {review.author.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-marron">{review.author}</p>
                  <p class="text-marron/40 text-xs">{review.source}</p>
                </div>
              </div>
              <StarRating rating={review.rating} size="sm" showNumber={false} />
            </div>
            <p class="text-marron/70 leading-relaxed">{review.text}</p>
          </div>
        </ScrollReveal>
      ))}
    </div>

    <!-- Formulario para dejar reseña -->
    <ScrollReveal delay={0.4}>
      <div class="mt-12 bg-white rounded-2xl p-8 shadow-lg">
        <h3 class="text-2xl font-bold text-marron mb-2">Dejanos tu reseña</h3>
        <p class="text-marron/50 text-sm mb-6">Tu opinión nos ayuda a mejorar</p>
        <form id="review-form" class="space-y-4" onsubmit="return submitReview(event)">
          <div>
            <input
              type="text"
              id="review-author"
              placeholder="Tu nombre"
              required
              class="w-full px-4 py-3 border border-cream-dark rounded-lg bg-warm-white text-marron placeholder-marron/40 focus:outline-none focus:ring-2 focus:ring-rojo/30"
            />
          </div>
          <div>
            <select
              id="review-rating"
              class="w-full px-4 py-3 border border-cream-dark rounded-lg bg-warm-white text-marron focus:outline-none focus:ring-2 focus:ring-rojo/30"
            >
              <option value="5">⭐⭐⭐⭐⭐ - Excelente</option>
              <option value="4">⭐⭐⭐⭐ - Muy bueno</option>
              <option value="3">⭐⭐⭐ - Bueno</option>
              <option value="2">⭐⭐ - Regular</option>
              <option value="1">⭐ - Malo</option>
            </select>
          </div>
          <div>
            <textarea
              id="review-text"
              placeholder="Escribí tu reseña..."
              required
              rows="4"
              class="w-full px-4 py-3 border border-cream-dark rounded-lg bg-warm-white text-marron placeholder-marron/40 focus:outline-none focus:ring-2 focus:ring-rojo/30"
            ></textarea>
          </div>
          <div class="flex items-center gap-4">
            <button
              type="submit"
              id="review-submit-btn"
              class="px-6 py-3 bg-rojo text-cream rounded-lg font-medium hover:bg-rojo-dark transition-colors border-none cursor-pointer"
            >
              Enviar reseña
            </button>
            <span id="review-form-status" class="text-sm text-marron/50"></span>
          </div>
        </form>
      </div>
    </ScrollReveal>
  </div>
</section>

<script>
  async function submitReview(e) {
    e.preventDefault();
    const btn = document.getElementById('review-submit-btn');
    const status = document.getElementById('review-form-status');
    btn.disabled = true;
    status.textContent = 'Enviando...';

    try {
      const res = await fetch('/api/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          author: document.getElementById('review-author').value,
          rating: Number(document.getElementById('review-rating').value),
          text: document.getElementById('review-text').value,
          source: 'web',
        }),
      });

      if (!res.ok) throw new Error('Error al enviar');

      status.textContent = '✅ ¡Gracias! Tu reseña será revisada pronto.';
      document.getElementById('review-form').reset();
    } catch (err) {
      status.textContent = 'Error al enviar. Intentalo de nuevo.';
    } finally {
      btn.disabled = false;
    }
    return false;
  }
</script>
