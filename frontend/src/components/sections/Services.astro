---
export interface Props {
  business: any;
}

const { business } = Astro.props;

import ScrollReveal from '../effects/ScrollReveal.astro';

const title = business.services_title || 'Nuestros Servicios';
const subtitle = business.services_subtitle || 'Lo que ofrecemos';
const desc = business.services_description || 'Cada producto está hecho con amor y los mejores ingredientes';
---

<section class="py-24 px-6 bg-warm-white">
  <div class="max-w-6xl mx-auto">
    <ScrollReveal>
      <div class="text-center mb-16">
        <span class="inline-block text-rojo font-semibold text-sm tracking-widest uppercase mb-4">
          {title}
        </span>
        <h2 class="text-4xl md:text-5xl font-bold text-marron mb-4">
          {subtitle}
        </h2>
        <p class="text-marron/60 text-lg max-w-2xl mx-auto">
          {desc}
        </p>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {business.services.map((service, i) => (
        <ScrollReveal delay={i * 0.1}>
          <div class="group relative rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-rojo/10">
            {/* Background image */}
            <div class="absolute inset-0">
              <img
                src={service.image || '/images/google-photo-1.jpg'}
                alt=""
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-marron/85 via-terracota/60 to-marron/30"></div>
            </div>

            {/* Content */}
            <div class="relative p-8 min-h-[250px] flex flex-col justify-end">
              <div class="text-3xl mb-3">{service.icon || '✨'}</div>
              <h3 class="text-xl font-bold text-cream mb-2 group-hover:text-amarillo transition-colors">
                {service.title}
              </h3>
              <p class="text-cream/70 leading-relaxed text-sm">
                {service.description}
              </p>
            </div>

            {/* Decorative corner */}
            <div class="absolute top-0 right-0 w-16 h-16 bg-amarillo/10 rounded-bl-2xl rounded-tr-2xl transition-all duration-300 group-hover:bg-amarillo/20"></div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
