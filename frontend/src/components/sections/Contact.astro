---
import business from '../../data/business.json';
import Button from '../ui/Button.astro';
import ScrollReveal from '../effects/ScrollReveal.astro';
---

<section class="py-24 px-6 bg-warm-white">
  <div class="max-w-4xl mx-auto">
    <ScrollReveal>
      <div class="text-center mb-12">
        <span class="inline-block text-rojo font-semibold text-sm tracking-widest uppercase mb-4">
          Contacto
        </span>
        <h2 class="text-4xl md:text-5xl font-bold text-marron mb-4">
          ¿Hablamos?
        </h2>
        <p class="text-marron/60 text-lg max-w-xl mx-auto">
          Estamos a un mensaje de distancia. Contáctanos por teléfono o visítanos
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal delay={0.1}>
      <div class="bg-cream rounded-2xl p-8 md:p-12 shadow-lg">
        <div class="grid sm:grid-cols-2 gap-8">
          <!-- Phone -->
          <a
            href={`tel:${business.phone}`}
            class="group flex flex-col items-center text-center p-6 rounded-xl bg-white hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-full bg-rojo/10 flex items-center justify-center mb-4 group-hover:bg-rojo/20 transition-colors">
              <svg class="w-7 h-7 text-rojo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="font-bold text-marron text-lg mb-1">Teléfono</h3>
            <p class="text-marron/70">{business.phone}</p>
          </a>

          <!-- WhatsApp -->
          <a
            href={`https://wa.me/${business.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center text-center p-6 rounded-xl bg-white hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors">
              <svg class="w-7 h-7 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.526 3.66 1.438 5.168L2 22l4.832-1.438C8.34 21.474 10.11 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.589 0-3.09-.433-4.383-1.186l-.314-.198-2.724.81.81-2.724-.198-.314A7.967 7.967 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z" />
              </svg>
            </div>
            <h3 class="font-bold text-marron text-lg mb-1">WhatsApp</h3>
            <p class="text-marron/70">Envíanos un mensaje</p>
          </a>

          <!-- Location -->
          <a
            href={business.google_maps_url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center text-center p-6 rounded-xl bg-white hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-full bg-rojo/10 flex items-center justify-center mb-4 group-hover:bg-rojo/20 transition-colors">
              <svg class="w-7 h-7 text-rojo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-marron text-lg mb-1">Dirección</h3>
            <p class="text-marron/70">{business.address.street}</p>
            <p class="text-marron/50 text-sm">{business.address.city}, {business.address.province}</p>
          </a>

          <!-- Instagram -->
          <a
            href={business.instagram ? `https://instagram.com/${business.instagram}` : '#'}
            target="_blank"
            rel="noopener noreferrer"
            class:list={{ 'opacity-50 pointer-events-none': !business.instagram }}
            class="group flex flex-col items-center text-center p-6 rounded-xl bg-white hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-full bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-500 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
              </svg>
            </div>
            <h3 class="font-bold text-marron text-lg mb-1">Instagram</h3>
            <p class="text-marron/70">{business.instagram ? `@${business.instagram}` : 'Próximamente'}</p>
          </a>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
