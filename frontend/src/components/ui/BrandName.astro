---
export interface Props {
  class?: string;
  variant?: "light" | "dark";
}

const { class: className = "", variant = "dark" } = Astro.props;

const c = {
  light: {
    cafe: "text-cream",
    mi: "text-amarillo",
    tie: "text-azul-light",
    rra: "text-rojo-light",
  },
  dark: {
    cafe: "text-marron",
    mi: "text-amarillo",
    tie: "text-azul",
    rra: "text-rojo",
  },
}[variant];
---

<span class={`inline ${className}`}>
  <span class={c.cafe}>Café</span>{' '}
  <span class={c.mi}>Mi</span>{' '}
  <span class={c.tie}>Tie</span><span class={c.rra}>rra</span>
</span>
