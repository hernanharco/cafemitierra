---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Menú" currentPath={Astro.url.pathname}>
  <div class="flex flex-col items-center justify-center py-16 text-center">
    <div class="text-6xl mb-4">📋</div>
    <h2 class="text-2xl font-bold text-marron mb-2">Gestión de Menú</h2>
    <p class="text-marron/60 max-w-md mb-8">
      Esta sección está en desarrollo. Pronto podrás gestionar el menú
      de comidas y bebidas desde aquí.
    </p>
    <a
      href="/admin"
      class="inline-flex items-center gap-2 px-6 py-3 bg-rojo text-white font-medium rounded-lg hover:bg-rojo-dark transition-colors"
    >
      ← Volver al Dashboard
    </a>
  </div>
</AdminLayout>
