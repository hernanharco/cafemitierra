---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Servicios" currentPath={Astro.url.pathname}>
  <!-- Textos de la sección -->
  <div class="form-card max-w-2xl mb-8">
    <h2 class="text-lg font-bold text-zinc-800 mb-4">Textos de la sección</h2>
    <form id="section-form" class="space-y-4">
      <div class="form-group">
        <label for="srv-title">Título de la sección</label>
        <input type="text" id="srv-title" class="form-input" placeholder="Nuestros Servicios" />
      </div>
      <div class="form-group">
        <label for="srv-subtitle">Subtítulo</label>
        <input type="text" id="srv-subtitle" class="form-input" placeholder="Lo que ofrecemos" />
      </div>
      <div class="form-group">
        <label for="srv-description">Descripción</label>
        <input type="text" id="srv-description" class="form-input" placeholder="Cada producto está hecho con amor..." />
      </div>
      <div class="flex gap-3 items-center pt-2">
        <button type="submit" class="btn-primary">💾 Guardar textos</button>
        <span id="section-status" class="text-sm text-zinc-400"></span>
      </div>
    </form>
  </div>

  <!-- Lista de servicios -->
  <div class="form-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-zinc-800">Servicios</h2>
      <button id="add-service-btn" class="btn-primary">➕ Nuevo Servicio</button>
    </div>
    <div id="services-list" class="space-y-3">
      <p class="text-zinc-400 text-sm">Cargando...</p>
    </div>
  </div>

  <!-- Modal: Nuevo/Editar Servicio -->
  <dialog id="service-modal" class="modal">
    <form id="service-form" class="modal-form">
      <div class="modal-header">
        <h2 id="service-modal-title">Nuevo Servicio</h2>
        <button type="button" class="modal-close" id="service-close-btn">✕</button>
      </div>
      <div class="modal-body space-y-4">
        <input type="hidden" id="service-index" />
        <div class="form-group">
          <label for="svc-title">Título *</label>
          <input type="text" id="svc-title" required class="form-input" placeholder="Café Colombiano" />
        </div>
        <div class="form-group">
          <label for="svc-description">Descripción *</label>
          <textarea id="svc-description" required class="form-input" rows="3" placeholder="Descripción del servicio..."></textarea>
        </div>
        <div class="form-group">
          <label>Icono</label>
          <input type="hidden" id="svc-icon" />
          <div class="emoji-grid" id="emoji-grid">
            <button type="button" class="emoji-btn" data-emoji="☕">☕</button>
            <button type="button" class="emoji-btn" data-emoji="🫖">🫖</button>
            <button type="button" class="emoji-btn" data-emoji="🧋">🧋</button>
            <button type="button" class="emoji-btn" data-emoji="🍵">🍵</button>
            <button type="button" class="emoji-btn" data-emoji="🥤">🥤</button>
            <button type="button" class="emoji-btn" data-emoji="🥖">🥖</button>
            <button type="button" class="emoji-btn" data-emoji="🥐">🥐</button>
            <button type="button" class="emoji-btn" data-emoji="🍞">🍞</button>
            <button type="button" class="emoji-btn" data-emoji="🥨">🥨</button>
            <button type="button" class="emoji-btn" data-emoji="🧀">🧀</button>
            <button type="button" class="emoji-btn" data-emoji="🥗">🥗</button>
            <button type="button" class="emoji-btn" data-emoji="🍳">🍳</button>
            <button type="button" class="emoji-btn" data-emoji="🥞">🥞</button>
            <button type="button" class="emoji-btn" data-emoji="🧇">🧇</button>
            <button type="button" class="emoji-btn" data-emoji="🍰">🍰</button>
            <button type="button" class="emoji-btn" data-emoji="🎂">🎂</button>
            <button type="button" class="emoji-btn" data-emoji="🍩">🍩</button>
            <button type="button" class="emoji-btn" data-emoji="🍪">🍪</button>
            <button type="button" class="emoji-btn" data-emoji="🥮">🥮</button>
            <button type="button" class="emoji-btn" data-emoji="🌮">🌮</button>
            <button type="button" class="emoji-btn" data-emoji="🥙">🥙</button>
            <button type="button" class="emoji-btn" data-emoji="🍝">🍝</button>
            <button type="button" class="emoji-btn" data-emoji="🥘">🥘</button>
            <button type="button" class="emoji-btn" data-emoji="🍕">🍕</button>
            <button type="button" class="emoji-btn" data-emoji="🌯">🌯</button>
            <button type="button" class="emoji-btn" data-emoji="🍎">🍎</button>
            <button type="button" class="emoji-btn" data-emoji="🥭">🥭</button>
            <button type="button" class="emoji-btn" data-emoji="🍌">🍌</button>
            <button type="button" class="emoji-btn" data-emoji="🍇">🍇</button>
            <button type="button" class="emoji-btn" data-emoji="🍓">🍓</button>
            <button type="button" class="emoji-btn" data-emoji="🍯">🍯</button>
            <button type="button" class="emoji-btn" data-emoji="🌿">🌿</button>
            <button type="button" class="emoji-btn" data-emoji="✨">✨</button>
            <button type="button" class="emoji-btn" data-emoji="🌟">🌟</button>
            <button type="button" class="emoji-btn" data-emoji="🎯">🎯</button>
          </div>
        </div>
        <div class="form-group">
          <label for="svc-image">Imagen (URL)</label>
          <div class="flex gap-2">
            <input type="text" id="svc-image" class="form-input" placeholder="URL de la imagen" />
            <button type="button" class="btn-secondary" id="pick-img-btn">📸</button>
          </div>
          <img id="svc-image-preview" class="hidden mt-2 max-h-32 rounded-lg" />
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary" id="service-cancel-btn">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar</button>
      </div>
    </form>
  </dialog>
</AdminLayout>

<script>
  function getToken() { return document.cookie.split('; ').find(r => r.startsWith('token='))?.split('=')[1]; }
  async function api(path: string, opts: any = {}) {
    const token = getToken();
    const res = await fetch(path, {
      headers: { 'Content-Type': 'application/json', ...(token ? { Authorization: `Bearer ${token}` } : {}), ...opts.headers },
      credentials: 'include',
      ...opts,
    });
    if (!res.ok) throw new Error(`Error: ${res.status}`);
    return res.json();
  }

  let services: any[] = [];

  // ── Cargar ────────────────────────────────────────────────────
  async function load() {
    try {
      const data = await api('/api/site');
      services = data.services || [];
      (document.getElementById('srv-title') as HTMLInputElement).value = data.services_title || '';
      (document.getElementById('srv-subtitle') as HTMLInputElement).value = data.services_subtitle || '';
      (document.getElementById('srv-description') as HTMLInputElement).value = data.services_description || '';
      render();
    } catch (err: any) {
      document.getElementById('services-list')!.innerHTML = `<p class="text-red-500 text-sm">Error: ${err.message}</p>`;
    }
  }

  function render() {
    const container = document.getElementById('services-list')!;
    if (services.length === 0) {
      container.innerHTML = '<p class="text-zinc-400 text-sm">No hay servicios aún</p>';
      return;
    }
    container.innerHTML = services.map((s: any, i: number) => `
      <div class="service-item">
        <div class="service-item-left">
          ${s.image ? `<img src="${s.image}" class="service-thumb" />` : `<div class="service-thumb-placeholder">📷</div>`}
          <div class="min-w-0">
            <p class="service-item-title">${s.icon || ''} ${s.title}</p>
            <p class="service-item-desc">${s.description}</p>
          </div>
        </div>
        <div class="service-item-actions">
          <button class="btn-icon edit-btn" data-index="${i}" title="Editar">✏️</button>
          <button class="btn-icon delete-btn" data-index="${i}" title="Eliminar">🗑️</button>
        </div>
      </div>
    `).join('');
    container.querySelectorAll('.edit-btn').forEach(b => b.addEventListener('click', () => openModal(Number((b as HTMLElement).dataset.index))));
    container.querySelectorAll('.delete-btn').forEach(b => b.addEventListener('click', () => deleteService(Number((b as HTMLElement).dataset.index))));
  }

  // ── Guardar textos sección ────────────────────────────────────
  document.getElementById('section-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('section-status')!;
    status.textContent = 'Guardando...';
    try {
      await api('/api/site', {
        method: 'PUT',
        body: JSON.stringify({
          services_title: (document.getElementById('srv-title') as HTMLInputElement).value,
          services_subtitle: (document.getElementById('srv-subtitle') as HTMLInputElement).value,
          services_description: (document.getElementById('srv-description') as HTMLInputElement).value,
        }),
      });
      status.textContent = '✅ Guardado';
      setTimeout(() => status.textContent = '', 3000);
    } catch (err: any) {
      status.textContent = 'Error: ' + err.message;
    }
  });

  // ── Modal servicios ──────────────────────────────────────────
  const modal = document.getElementById('service-modal') as HTMLDialogElement;
  const form = document.getElementById('service-form')!;

  function openModal(index = -1) {
    document.getElementById('service-modal-title')!.textContent = index >= 0 ? 'Editar Servicio' : 'Nuevo Servicio';
    (document.getElementById('service-index') as HTMLInputElement).value = String(index);
    const s = index >= 0 ? services[index] : null;
    (document.getElementById('svc-title') as HTMLInputElement).value = s?.title ?? '';
    (document.getElementById('svc-description') as HTMLInputElement).value = s?.description ?? '';
    (document.getElementById('svc-icon') as HTMLInputElement).value = s?.icon ?? '';
    document.querySelectorAll('.emoji-btn').forEach(b => {
      b.classList.toggle('active', (b as HTMLElement).dataset.emoji === s?.icon);
    });
    (document.getElementById('svc-image') as HTMLInputElement).value = s?.image ?? '';
    const preview = document.getElementById('svc-image-preview') as HTMLImageElement;
    if (s?.image) { preview.src = s.image; preview.classList.remove('hidden'); }
    else preview.classList.add('hidden');
    modal.showModal();
  }

  // ── Selector de emojis ────────────────────────────────────────
  document.querySelectorAll('.emoji-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.emoji-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      (document.getElementById('svc-icon') as HTMLInputElement).value = (btn as HTMLElement).dataset.emoji!;
    });
  });

  document.getElementById('add-service-btn')!.addEventListener('click', () => openModal());
  document.getElementById('service-close-btn')!.addEventListener('click', () => modal.close());
  document.getElementById('service-cancel-btn')!.addEventListener('click', () => modal.close());
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

  // Preview imagen al escribir URL
  document.getElementById('svc-image')!.addEventListener('input', (e) => {
    const preview = document.getElementById('svc-image-preview') as HTMLImageElement;
    if ((e.target as HTMLInputElement).value) { preview.src = (e.target as HTMLInputElement).value; preview.classList.remove('hidden'); }
    else preview.classList.add('hidden');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const index = Number((document.getElementById('service-index') as HTMLInputElement).value);
    const item = {
      title: (document.getElementById('svc-title') as HTMLInputElement).value,
      description: (document.getElementById('svc-description') as HTMLInputElement).value,
      icon: (document.getElementById('svc-icon') as HTMLInputElement).value,
      image: (document.getElementById('svc-image') as HTMLInputElement).value || undefined,
    };
    if (index >= 0) services[index] = item;
    else services.push(item);
    try {
      await api('/api/site/services', { method: 'PUT', body: JSON.stringify(services) });
      modal.close();
      render();
    } catch (err: any) {
      window.showToast('Error: ' + err.message, { type: 'error' });
    }
  });

  async function deleteService(index: number) {
    const confirmed = await window.showConfirm('¿Eliminar este servicio?', { title: 'Eliminar servicio' });
    if (!confirmed) return;
    services.splice(index, 1);
    try {
      await api('/api/site/services', { method: 'PUT', body: JSON.stringify(services) });
      render();
    } catch (err: any) {
      window.showToast('Error: ' + err.message, { type: 'error' });
    }
  }

  load();
</script>

<style is:global>
  @reference "tailwindcss";
  .form-card { @apply bg-white rounded-xl border border-zinc-200 p-6; }
  .form-group { @apply space-y-1; }
  .form-group label { @apply block text-sm font-medium text-zinc-700; }
  .form-input { @apply w-full px-3 py-2 border border-zinc-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent; }
  .btn-primary { @apply px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors cursor-pointer border-none font-medium text-sm; }
  .btn-secondary { @apply px-4 py-2 bg-zinc-100 text-zinc-700 rounded-lg hover:bg-zinc-200 transition-colors cursor-pointer border-none font-medium text-sm; }
  .service-item { @apply flex items-center justify-between p-3 border border-zinc-100 rounded-lg; }
  .service-item-left { @apply flex items-center gap-3 flex-1 min-w-0; }
  .service-thumb { @apply w-12 h-12 object-cover rounded-lg; }
  .service-thumb-placeholder { @apply w-12 h-12 bg-zinc-100 rounded-lg flex items-center justify-center text-lg; }
  .service-item-title { @apply text-sm font-medium text-zinc-800; }
  .service-item-desc { @apply text-xs text-zinc-500 truncate max-w-xs; }
  .service-item-actions { @apply flex gap-1 shrink-0; }
  .btn-icon { @apply p-1.5 rounded hover:bg-zinc-100 transition-colors cursor-pointer bg-transparent border-none text-sm; }
  .modal { @apply rounded-xl border-none shadow-2xl p-0 max-w-lg w-full; }
  .modal::backdrop { @apply bg-black/50; }
  .modal-header { @apply flex items-center justify-between px-6 py-4 border-b border-zinc-200; }
  .modal-header h2 { @apply text-lg font-bold text-zinc-800; }
  .modal-close { @apply p-1 hover:bg-zinc-100 rounded transition-colors cursor-pointer bg-transparent border-none text-zinc-500; }
  .modal-body { @apply px-6 py-4; }
  .modal-footer { @apply px-6 py-4 border-t border-zinc-200 flex justify-end gap-3; }
  .emoji-grid { @apply flex flex-wrap gap-1.5 p-2 bg-zinc-50 rounded-lg border border-zinc-200 max-h-32 overflow-y-auto; }
  .emoji-btn { @apply w-9 h-9 flex items-center justify-center rounded-lg text-lg hover:bg-amber-100 transition-colors cursor-pointer border-none bg-transparent; }
  .emoji-btn.active { @apply bg-amber-200 ring-2 ring-amber-500; }
</style>
