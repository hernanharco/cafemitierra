---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Reseñas" currentPath={Astro.url.pathname}>
  <div class="mb-4">
    <p class="text-sm text-zinc-500">
      Las reseñas de clientes aparecen en la web solo cuando están <strong>aprobadas ✅</strong>.
      Las nuevas reseñas llegan como <strong>pendientes ⏳</strong>.
    </p>
  </div>

  <!-- ===== DESKTOP: Tabla ===== -->
  <div class="table-container hidden sm:block">
    <table class="data-table">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Autor</th>
          <th class="w-24">Rating</th>
          <th>Texto</th>
          <th>Fuente</th>
          <th class="w-24">Estado</th>
          <th class="w-24">Acciones</th>
        </tr>
      </thead>
      <tbody id="reviews-table-body">
        <tr>
          <td colspan="7" class="text-center text-zinc-400 py-8">Cargando...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ===== MOBILE: Cards ===== -->
  <div id="reviews-cards" class="sm:hidden space-y-3">
    <p class="text-center text-zinc-400 py-8 text-sm">Cargando...</p>
  </div>
</AdminLayout>

<script>
  function getToken() { return document.cookie.split('; ').find(r => r.startsWith('token='))?.split('=')[1]; }
  async function api(path, opts = {}) {
    const token = getToken();
    const res = await fetch(path, {
      headers: { 'Content-Type': 'application/json', ...(token ? { Authorization: `Bearer ${token}` } : {}), ...opts.headers },
      credentials: 'include',
      ...opts,
    });
    if (!res.ok) throw new Error(`Error: ${res.status}`);
    return res.json();
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function formatDate(iso) {
    if (!iso) return '—';
    return new Date(iso).toLocaleDateString('es-ES', {
      day: '2-digit', month: '2-digit', year: 'numeric',
    });
  }

  function stars(rating) {
    return '⭐'.repeat(Math.round(rating || 5));
  }

  async function loadReviews() {
    const tbody = document.getElementById('reviews-table-body');
    const cardsContainer = document.getElementById('reviews-cards');
    try {
      const reviews = await api('/api/reviews');

      if (reviews.length === 0) {
        const empty = '<tr><td colspan="7" class="text-center text-zinc-400 py-8">No hay reseñas todavía</td></tr>';
        tbody.innerHTML = empty;
        cardsContainer.innerHTML = '<p class="text-center text-zinc-400 py-8 text-sm">No hay reseñas todavía</p>';
        return;
      }

      // ── Desktop: tabla ──
      tbody.innerHTML = reviews.map(r => {
        const created = formatDate(r.createdAt);
        return `
        <tr class="${r.visible ? '' : 'bg-amber-50/50'}">
          <td class="text-xs text-zinc-400 whitespace-nowrap">${created}</td>
          <td class="font-medium">${escapeHtml(r.author)}</td>
          <td class="whitespace-nowrap">${stars(r.rating)}</td>
          <td class="max-w-xs truncate text-zinc-500">${escapeHtml(r.text)}</td>
          <td class="text-zinc-500 text-xs">${r.source || 'manual'}</td>
          <td>
            ${r.visible
              ? '<span class="badge badge-approved">✅ Aprobada</span>'
              : '<span class="badge badge-pending">⏳ Pendiente</span>'
            }
          </td>
          <td>
            <div class="action-buttons">
              <button class="btn-icon toggle-btn" data-id="${r.id}" data-visible="${r.visible}" title="${r.visible ? 'Rechazar' : 'Aprobar'}">
                ${r.visible ? '⛔' : '✅'}
              </button>
              <button class="btn-icon delete-btn" data-id="${r.id}" title="Eliminar">🗑️</button>
            </div>
          </td>
        </tr>`;
      }).join('');

      // ── Mobile: cards ──
      cardsContainer.innerHTML = reviews.map(r => {
        const created = formatDate(r.createdAt);
        return `
        <div class="review-card ${r.visible ? '' : 'review-card-pending'}">
          <div class="review-card-header">
            <div class="review-card-user">
              <span class="review-card-author">${escapeHtml(r.author)}</span>
              <span class="review-card-stars">${stars(r.rating)}</span>
            </div>
            <span class="review-card-date">${created}</span>
          </div>
          <p class="review-card-text">${escapeHtml(r.text)}</p>
          <div class="review-card-footer">
            <div class="review-card-meta">
              <span class="text-xs text-zinc-400">${r.source || 'manual'}</span>
              <span class="${r.visible ? 'badge badge-approved' : 'badge badge-pending'}">
                ${r.visible ? '✅ Aprobada' : '⏳ Pendiente'}
              </span>
            </div>
            <div class="action-buttons">
              <button class="btn-icon toggle-btn" data-id="${r.id}" data-visible="${r.visible}" title="${r.visible ? 'Rechazar' : 'Aprobar'}">
                ${r.visible ? '⛔' : '✅'}
              </button>
              <button class="btn-icon delete-btn" data-id="${r.id}" title="Eliminar">🗑️</button>
            </div>
          </div>
        </div>`;
      }).join('');

      // Bind events
      document.querySelectorAll('.toggle-btn').forEach(b =>
        b.addEventListener('click', () => toggleReview(Number(b.dataset.id), b.dataset.visible === 'true'))
      );
      document.querySelectorAll('.delete-btn').forEach(b =>
        b.addEventListener('click', () => deleteReview(Number(b.dataset.id)))
      );
    } catch (err) {
      const errorMsg = '<tr><td colspan="7" class="text-center text-red-500 py-8">Error: ' + err.message + '</td></tr>';
      tbody.innerHTML = errorMsg;
      cardsContainer.innerHTML = '<p class="text-center text-red-500 py-8 text-sm">Error: ' + err.message + '</p>';
    }
  }

  async function toggleReview(id, currentVisible) {
    try {
      await api(`/api/reviews/${id}`, {
        method: 'PUT',
        body: JSON.stringify({ visible: !currentVisible }),
      });
      loadReviews();
    } catch (err) {
      window.showToast('Error: ' + err.message, { type: 'error' });
    }
  }

  async function deleteReview(id) {
    if (!confirm('¿Eliminar esta reseña?')) return;
    try {
      await api(`/api/reviews/${id}`, { method: 'DELETE' });
      loadReviews();
    } catch (err) {
      window.showToast('Error: ' + err.message, { type: 'error' });
    }
  }

  loadReviews();
</script>

<style is:global>
  @reference "tailwindcss";

  /* ── Desktop: Tabla ─────────────────────────────────────── */
  .table-container { @apply bg-white rounded-xl border border-zinc-200 overflow-x-auto; }
  .data-table { @apply w-full text-sm; }
  .data-table th { @apply text-left px-4 py-3 bg-zinc-50 text-zinc-600 font-medium border-b border-zinc-200 whitespace-nowrap; }
  .data-table td { @apply px-4 py-3 border-b border-zinc-100; }
  .action-buttons { @apply flex gap-1; }
  .btn-icon { @apply p-1.5 rounded hover:bg-zinc-100 transition-colors cursor-pointer bg-transparent border-none text-sm; }
  .badge { @apply inline-block px-2 py-0.5 rounded-full text-xs font-medium; }
  .badge-approved { @apply bg-green-100 text-green-700; }
  .badge-pending { @apply bg-amber-100 text-amber-700; }

  /* ── Mobile: Cards ──────────────────────────────────────── */
  .review-card {
    @apply bg-white rounded-xl border border-zinc-200 p-4;
  }
  .review-card-pending {
    @apply border-l-4 border-l-amber-500 bg-amber-50/30;
  }
  .review-card-header {
    @apply flex items-start justify-between gap-2 mb-2;
  }
  .review-card-user {
    @apply flex-1;
  }
  .review-card-author {
    @apply block text-sm font-semibold text-zinc-800;
  }
  .review-card-stars {
    @apply text-xs;
  }
  .review-card-date {
    @apply text-xs text-zinc-400 whitespace-nowrap;
  }
  .review-card-text {
    @apply text-sm text-zinc-600 mb-3;
  }
  .review-card-footer {
    @apply flex items-center justify-between pt-2 border-t border-zinc-100;
  }
  .review-card-meta {
    @apply flex items-center gap-2;
  }
</style>
