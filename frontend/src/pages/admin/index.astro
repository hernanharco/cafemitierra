---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard" currentPath={Astro.url.pathname}>
  <div class="dashboard-grid">
    <a href="/admin/hero" class="stat-card no-underline">
      <div class="stat-icon bg-amber-100 text-amber-600">🖼️</div>
      <div class="stat-info">
        <span class="stat-label">Hero / Carrusel</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>

    <a href="/admin/about" class="stat-card no-underline">
      <div class="stat-icon bg-blue-100 text-blue-600">📝</div>
      <div class="stat-info">
        <span class="stat-label">Nosotros</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>

    <a href="/admin/services" class="stat-card no-underline">
      <div class="stat-icon bg-purple-100 text-purple-600">⚙️</div>
      <div class="stat-info">
        <span class="stat-label">Servicios</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>

    <a href="/admin/schedule" class="stat-card no-underline">
      <div class="stat-icon bg-green-100 text-green-600">🕐</div>
      <div class="stat-info">
        <span class="stat-label">Horarios</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>

    <a href="/admin/info" class="stat-card no-underline">
      <div class="stat-icon bg-pink-100 text-pink-600">ℹ️</div>
      <div class="stat-info">
        <span class="stat-label">Información</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>

    <a href="/admin/gallery" class="stat-card no-underline">
      <div class="stat-icon bg-sky-100 text-sky-600">📸</div>
      <div class="stat-info">
        <span class="stat-value" id="gallery-count">—</span>
        <span class="stat-label">Imágenes en Galería</span>
      </div>
      <span class="stat-link">Gestionar →</span>
    </a>

    <a href="/admin/reviews" class="stat-card no-underline">
      <div class="stat-icon bg-yellow-100 text-yellow-600">⭐</div>
      <div class="stat-info">
        <span class="stat-value" id="reviews-count">—</span>
        <span class="stat-label">Reseñas</span>
      </div>
      <span class="stat-link">Gestionar →</span>
    </a>

    <a href="/admin/seo" class="stat-card no-underline">
      <div class="stat-icon bg-indigo-100 text-indigo-600">🔍</div>
      <div class="stat-info">
        <span class="stat-label">SEO</span>
      </div>
      <span class="stat-link">Editar →</span>
    </a>
  </div>
</AdminLayout>

<script>
  async function fetchWithAuth(url) {
    const token = document.cookie
      .split('; ')
      .find(row => row.startsWith('token='))
      ?.split('=')[1];
    const res = await fetch(url, {
      headers: { Authorization: `Bearer ${token}` },
    });
    return res.json();
  }

  async function loadDashboard() {
    try {
      const [galleryImages, reviews] = await Promise.all([
        fetchWithAuth('/api/gallery'),
        fetchWithAuth('/api/reviews'),
      ]);
      document.getElementById('gallery-count').textContent = galleryImages.length;
      document.getElementById('reviews-count').textContent = reviews.length;
    } catch (err) {
      console.error('Error cargando dashboard:', err);
    }
  }

  loadDashboard();
</script>

<style is:global>
  @reference "tailwindcss";
  .dashboard-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8;
  }
  .stat-card {
    @apply bg-white rounded-xl border border-zinc-200 p-6 relative block hover:border-amber-300 hover:shadow-sm transition-all;
  }
  .stat-card.no-underline {
    @apply no-underline;
  }
  .stat-icon {
    @apply w-12 h-12 rounded-lg flex items-center justify-center text-xl mb-3;
  }
  .stat-info {
    @apply mb-2;
  }
  .stat-value {
    @apply block text-3xl font-bold text-zinc-800;
  }
  .stat-label {
    @apply text-sm text-zinc-500;
  }
  .stat-link {
    @apply text-sm text-amber-600 hover:text-amber-700 font-medium;
  }
</style>
