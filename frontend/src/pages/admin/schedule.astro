---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Horarios" currentPath={Astro.url.pathname}>
  <div class="form-card max-w-xl">
    <form id="schedule-form" class="space-y-3">
      <div id="schedule-rows"></div>
      <div class="flex gap-3 items-center pt-4">
        <button type="submit" class="btn-primary" id="schedule-save-btn">💾 Guardar</button>
        <span id="schedule-status" class="text-sm text-zinc-400"></span>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  function getToken() { return document.cookie.split('; ').find(r => r.startsWith('token='))?.split('=')[1]; }
  async function api(path: string, opts: any = {}) {
    const token = getToken();
    const res = await fetch(path, {
      headers: { 'Content-Type': 'application/json', ...(token ? { Authorization: `Bearer ${token}` } : {}), ...opts.headers },
      ...opts,
    });
    if (!res.ok) throw new Error(`Error: ${res.status}`);
    return res.json();
  }

  const DAYS = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];

  async function load() {
    try {
      const data = await api('/api/site');
      const hours = data.hours || [];
      const container = document.getElementById('schedule-rows')!;
      container.innerHTML = DAYS.map((day: string) => {
        const entry = hours.find((h: any) => h.day === day) || { day, hours: '' };
        return `
          <div class="schedule-row">
            <label class="schedule-day">${day}</label>
            <input type="text" class="form-input schedule-input" data-day="${day}" value="${entry.hours}" placeholder="Cerrado" />
          </div>
        `;
      }).join('');
    } catch (err: any) {
      document.getElementById('schedule-status')!.textContent = 'Error: ' + err.message;
    }
  }

  document.getElementById('schedule-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('schedule-status')!;
    const btn = document.getElementById('schedule-save-btn') as HTMLButtonElement;
    btn.disabled = true;
    status.textContent = 'Guardando...';
    try {
      const inputs = document.querySelectorAll('.schedule-input');
      const hours = Array.from(inputs).map(input => ({
        day: (input as HTMLElement).dataset.day,
        hours: (input as HTMLInputElement).value.trim() || 'Cerrado',
      }));
      await api('/api/site/hours', { method: 'PUT', body: JSON.stringify(hours) });
      status.textContent = '✅ Guardado';
    } catch (err: any) {
      status.textContent = 'Error: ' + err.message;
    } finally {
      btn.disabled = false;
    }
  });

  load();
</script>

<style is:global>
  @reference "tailwindcss";
  .form-card { @apply bg-white rounded-xl border border-zinc-200 p-6; }
  .schedule-row { @apply flex items-center gap-4 py-2 border-b border-zinc-100 last:border-b-0; }
  .schedule-day { @apply w-28 text-sm font-medium text-zinc-700 shrink-0; }
  .schedule-input { @apply flex-1; }
  .form-input { @apply w-full px-3 py-2 border border-zinc-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent; }
  .btn-primary { @apply px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors cursor-pointer border-none font-medium text-sm disabled:opacity-50; }
</style>
