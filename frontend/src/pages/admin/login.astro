---
export const prerender = false;

import "../../styles/global.css";

// Página pública — no necesita autenticación

// ── URLs de API ──────────────────────────────────────────────
// BACKEND_URL: API del negocio (CafeMiTierra) — para CRUD del sitio
// AUTHCORE_URL: API de autenticación (authCore HUB) — para Google OAuth
const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || "http://localhost:8001";
const AUTHCORE_URL =
  import.meta.env.PUBLIC_AUTHCORE_URL || "https://api-authcore.elrincondeharco.com";

// Solo mostrar acceso de desarrollo en entorno local
const showDevLogin = import.meta.env.DEV;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — Café Mi Tierra Admin</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="min-h-screen bg-gradient-to-br from-amber-900 via-amber-800 to-zinc-900 flex items-center justify-center p-4">
    <div class="login-card">
      <div class="login-header">
        <span class="login-icon">☕</span>
        <h1>Café Mi Tierra</h1>
        <p class="login-subtitle">Panel de Administración</p>
      </div>

      <div class="login-body">
        <div id="dev-login" class="dev-login">
          <p class="text-sm text-zinc-500 mb-4 text-center">
            Inicia sesión para gestionar tu negocio
          </p>

          <button id="google-login" class="btn-google">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span>Continuar con Google</span>
          </button>

          {showDevLogin && (
            <>
              <div class="divider">
                <span>o</span>
              </div>

              <button id="dev-login-btn" class="btn-dev">
                <span>🔑</span>
                <span>Acceso de Desarrollo</span>
              </button>

              <p class="text-xs text-zinc-400 mt-4 text-center">
                El acceso de desarrollo es solo para pruebas locales
              </p>
            </>
          )}
        </div>
      </div>
    </div>

    <script define:vars={{ BACKEND_URL, AUTHCORE_URL }}>
      // ── Google Login (authCore) ──────────────────────────────
      document.getElementById('google-login')?.addEventListener('click', () => {
        const callbackUrl = `${window.location.origin}/auth/callback`;

        const authUrl = new URL(`${AUTHCORE_URL}/api/v1/auth/google`);
        authUrl.searchParams.set('redirect_to', callbackUrl);

        window.location.href = authUrl.toString();
      });

      // ── Dev Login (solo local) ───────────────────────────────
      document.getElementById('dev-login-btn')?.addEventListener('click', async () => {
        try {
          const res = await fetch(`${BACKEND_URL}/api/auth/dev-login`, {
            method: 'POST',
          });
          const data = await res.json();

          if (data.token) {
            // Guardar token en cookie (7 días)
            const expires = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toUTCString();
            document.cookie = `token=${data.token}; path=/; expires=${expires}; SameSite=Lax`;
            window.location.href = '/admin';
          }
        } catch (err) {
          window.showToast('Error de conexión con el backend', { type: 'error', duration: 6000 });
          console.error(err);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @reference "tailwindcss";
  .login-card {
    @apply w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden;
  }

  .login-header {
    @apply bg-gradient-to-r from-amber-800 to-amber-900 text-white p-8 text-center;
  }

  .login-icon {
    @apply text-5xl block mb-3;
  }

  .login-header h1 {
    @apply text-2xl font-bold mb-1;
  }

  .login-subtitle {
    @apply text-amber-200 text-sm;
  }

  .login-body {
    @apply p-8;
  }

  .btn-google {
    @apply w-full flex items-center justify-center gap-3 px-4 py-3 border border-zinc-300 rounded-lg text-zinc-700 font-medium text-sm hover:bg-zinc-50 transition-colors cursor-pointer;
  }

  .divider {
    @apply flex items-center gap-3 my-6 text-sm text-zinc-400;
  }

  .divider::before,
  .divider::after {
    content: '';
    @apply flex-1 h-px bg-zinc-200;
  }

  .btn-dev {
    @apply w-full flex items-center justify-center gap-2 px-4 py-3 bg-amber-600 text-white rounded-lg font-medium text-sm hover:bg-amber-700 transition-colors cursor-pointer border-none;
  }
</style>
