---
import BrandName from "../components/ui/BrandName.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Error del servidor — CafeMiTierra" description="Ocurrió un error inesperado.">
  <main class="min-h-screen flex flex-col items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <!-- Logo grande decorativo -->
      <div class="text-9xl font-bold font-['Playfair_Display'] text-rojo/10 select-none mb-4">
        500
      </div>

      <BrandName variant="dark" class="text-3xl mb-6" />

      <p class="text-lg text-marron-light mb-2">
        Algo salió mal en la cocina...
      </p>
      <p class="text-marron-light/70 mb-8">
        Nuestro equipo ya fue notificado. Mientras tanto, probá volver al inicio.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-rojo text-white font-medium rounded-lg hover:bg-rojo-dark hover:shadow-lg hover:shadow-rojo/25 transition-all duration-300 active:scale-95"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Volver al inicio
      </a>
    </div>
  </main>
</BaseLayout>
