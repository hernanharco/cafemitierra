---
// SSR: cargar datos frescos desde la API en cada visita
const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8001";
let business = {};

try {
  // Cargar datos del sitio
  const siteRes = await fetch(`${API_URL}/api/site`);
  if (siteRes.ok) business = await siteRes.json();

  // Cargar reseñas visibles desde la DB
  const reviewsRes = await fetch(`${API_URL}/api/reviews/public`);
  if (reviewsRes.ok) {
    const reviews = await reviewsRes.json();
    business.reviews = reviews;
  }
} catch (e) {
  console.error("Error al cargar datos del sitio:", e);
}

import SmoothScroll from "../components/effects/SmoothScroll.astro";
import About from "../components/sections/About.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/sections/Footer.astro";
import Gallery from "../components/sections/Gallery.astro";
import Hero from "../components/sections/Hero.astro";
import Reviews from "../components/sections/Reviews.astro";
import Schedule from "../components/sections/Schedule.astro";
import Services from "../components/sections/Services.astro";
import BrandName from "../components/ui/BrandName.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={business.seo?.title}
  description={business.seo?.description}
>
  <SmoothScroll>
    <!-- NAV -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-burdeos backdrop-blur-md border-b border-cream/10">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="#" class="text-cream font-bold text-xl font-serif"><BrandName variant="light" /></a>
        <div class="hidden md:flex items-center gap-8 text-sm">
          <a href="#nosotros" class="text-cream/70 hover:text-cream transition-colors">Nosotros</a>
          <a href="#servicios" class="text-cream/70 hover:text-cream transition-colors">Servicios</a>
          <a href="#horarios" class="text-cream/70 hover:text-cream transition-colors">Horarios</a>
          <a href="#galeria" class="text-cream/70 hover:text-cream transition-colors">Galería</a>
          <a href="#contacto" class="text-cream/70 hover:text-cream transition-colors">Contacto</a>
        </div>
        <a
          href="tel:643945651"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-rojo text-white text-sm font-medium hover:bg-rojo-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Llamar
        </a>
      </div>
    </nav>

    <!-- HERO -->
    <section id="inicio">
      <Hero business={business} />
    </section>

    <!-- ABOUT -->
    <section id="nosotros">
      <About business={business} />
    </section>

    <!-- SERVICES -->
    <section id="servicios">
      <Services business={business} />
    </section>

    <!-- SCHEDULE -->
    <section id="horarios">
      <Schedule business={business} />
    </section>

    <!-- REVIEWS -->
    <section id="resenas">
      <Reviews business={business} />
    </section>

    <!-- GALLERY -->
    <section id="galeria">
      <Gallery business={business} />
    </section>

    <!-- CONTACT -->
    <section id="contacto">
      <Contact business={business} />
    </section>

    <!-- FOOTER -->
    <Footer business={business} />
  </SmoothScroll>
</BaseLayout>
