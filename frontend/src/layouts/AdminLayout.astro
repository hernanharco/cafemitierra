---
import "../styles/global.css";
import Sidebar from "../components/admin/Sidebar.astro";

export interface Props {
  title: string;
  currentPath: string;
}

const { title, currentPath } = Astro.props;

// URL base de la API de CafeMiTierra (backend)
const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8001";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Café Mi Tierra Admin</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script define:vars={{ API_URL }}>
      // Parchear fetch para que las URLs /api/* vayan al backend correcto
      const origFetch = window.fetch;
      window.fetch = function(url, options = {}) {
        if (typeof url === 'string' && url.startsWith('/api/') && !url.startsWith('http')) {
          url = `${API_URL}${url}`;
        }
        return origFetch.call(this, url, options);
      };
    </script>
  </head>
  <body class="bg-zinc-50 text-zinc-900">
    <Sidebar currentPath={currentPath} />

    <div class="admin-main">
      <header class="admin-header">
        <h1 class="page-title">{title}</h1>
        <div class="header-right">
          <span class="user-info" id="user-info">Cargando...</span>
        </div>
      </header>

      <main class="admin-content">
        <slot />
      </main>
    </div>

    <script>
      // Mostrar info del usuario (el middleware ya verificó el token server-side)
      const token = document.cookie
        .split('; ')
        .find(row => row.startsWith('token='))
        ?.split('=')[1];

      const userInfo = document.getElementById('user-info');
      if (userInfo && token) {
        try {
          const payload = JSON.parse(atob(token.split('.')[0]));
          userInfo.textContent = payload.email || 'Admin';
        } catch {
          userInfo.textContent = 'Dev Admin';
        }
      }
    </script>
  </body>
</html>

<style is:global>
  @reference "tailwindcss";
  .admin-main {
    @apply ml-64 min-h-screen;
  }

  .admin-header {
    @apply sticky top-0 z-30 bg-white border-b border-zinc-200 px-8 py-4 flex items-center justify-between;
  }

  .page-title {
    @apply text-xl font-bold text-zinc-800;
  }

  .header-right {
    @apply flex items-center gap-3;
  }

  .user-info {
    @apply text-sm text-zinc-500;
  }

  .admin-content {
    @apply p-8;
  }
</style>
