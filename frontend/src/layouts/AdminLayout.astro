---
import "../styles/global.css";
import Sidebar from "../components/admin/Sidebar.astro";
import Toast from "../components/admin/Toast.astro";

export interface Props {
  title: string;
  currentPath: string;
}

const { title, currentPath } = Astro.props;

// URL base de la API de CafeMiTierra (backend)
const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:8001";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Café Mi Tierra Admin</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script is:inline define:vars={{ API_URL }}>
      // Redirect API calls directly to backend (bypass Vercel serverless body limit)
      const origFetch = window.fetch;
      window.fetch = function(url, options = {}) {
        if (typeof url === 'string' && url.startsWith('/api/') && !url.startsWith('http')) {
          url = `${API_URL}${url}`;
        }
        return origFetch.call(this, url, options);
      };
    </script>
  </head>
  <body class="bg-zinc-50 text-zinc-900">
    <Toast />

    <!-- Overlay para mobile cuando el sidebar está abierto -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <Sidebar currentPath={currentPath} />

    <div class="admin-main">
      <header class="admin-header">
        <div class="admin-header-left">
          <!-- Hamburger (mobile) -->
          <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Abrir menú">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </button>
          <h1 class="page-title">{title}</h1>
        </div>
        <div class="header-right">
          <span class="user-info" id="user-info">Cargando...</span>
        </div>
      </header>

      <main class="admin-content">
        <slot />
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const toggle = document.getElementById('sidebar-toggle');

      function openSidebar() {
        sidebar?.classList.add('open');
        overlay?.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('open');
        document.body.style.overflow = '';
      }

      toggle?.addEventListener('click', openSidebar);
      overlay?.addEventListener('click', closeSidebar);

      // Cerrar sidebar al hacer clic en un link (mobile)
      sidebar?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth < 768) closeSidebar();
        });
      });

      // Cerrar al hacer resize a desktop
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) closeSidebar();
      });

      // Mostrar info del usuario
      const token = document.cookie
        .split('; ')
        .find(row => row.startsWith('token='))
        ?.split('=')[1];

      const userInfo = document.getElementById('user-info');
      if (userInfo && token) {
        try {
          const payload = JSON.parse(atob(token.split('.')[0]));
          userInfo.textContent = payload.email || 'Admin';
        } catch {
          userInfo.textContent = 'Admin';
        }
      }
    </script>
  </body>
</html>

<style is:global>
  @reference "tailwindcss";

  /* ── Layout ─────────────────────────────────────────────── */
  .admin-main {
    @apply ml-0 min-h-screen;
  }

  .admin-header {
    @apply sticky top-0 z-30 bg-white border-b border-zinc-200 px-4 sm:px-8 py-4 flex items-center justify-between;
  }

  .admin-header-left {
    @apply flex items-center gap-3;
  }

  .page-title {
    @apply text-lg sm:text-xl font-bold text-zinc-800;
  }

  .header-right {
    @apply flex items-center gap-3;
  }

  .user-info {
    @apply text-xs sm:text-sm text-zinc-500;
  }

  .admin-content {
    @apply p-4 sm:p-8;
  }

  /* ── Hamburger button ───────────────────────────────────── */
  .sidebar-toggle {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 6px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 6px;
  }

  .sidebar-toggle:hover {
    background: #f4f4f5;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: #52525b;
    border-radius: 1px;
    transition: transform 0.2s;
  }

  /* ── Overlay (mobile) ───────────────────────────────────── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 35;
  }

  .sidebar-overlay.open {
    display: block;
  }

  /* ── Desktop: sidebar fijo con margen ───────────────────── */
  @media (min-width: 768px) {
    .sidebar-toggle {
      display: none;
    }

    .admin-main {
      @apply ml-64;
    }

    .sidebar-overlay {
      display: none !important;
    }
  }
</style>
