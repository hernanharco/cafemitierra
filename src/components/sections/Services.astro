---
import business from '../../data/business.json';
import ScrollReveal from '../effects/ScrollReveal.astro';

const iconMap: Record<string, string> = {
  coffee: '☕',
  bread: '🥖',
  breakfast: '🍳',
  brunch: '🥂',
};

const serviceImages: Record<string, string> = {
  coffee: '/images/coffee-cup.jpg',
  bread: '/images/bakery.jpg',
  breakfast: '/images/breakfast.jpg',
  brunch: '/images/brunch.jpg',
};
---

<section class="py-24 px-6 bg-warm-white">
  <div class="max-w-6xl mx-auto">
    <ScrollReveal>
      <div class="text-center mb-16">
        <span class="inline-block text-terracota font-semibold text-sm tracking-widest uppercase mb-4">
          Nuestros Servicios
        </span>
        <h2 class="text-4xl md:text-5xl font-bold text-coffee mb-4">
          Lo que ofrecemos
        </h2>
        <p class="text-coffee/60 text-lg max-w-2xl mx-auto">
          Cada producto está hecho con amor y los mejores ingredientes
        </p>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {business.services.map((service, i) => (
        <ScrollReveal delay={i * 0.1}>
          <div class="group relative rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-terracota/10">
            {/* Background image */}
            <div class="absolute inset-0">
              <img
                src={serviceImages[service.icon] || '/images/cafe-interior.jpg'}
                alt=""
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-coffee/95 via-coffee/70 to-coffee/40"></div>
            </div>

            {/* Content */}
            <div class="relative p-8 min-h-[250px] flex flex-col justify-end">
              <div class="text-3xl mb-3">{iconMap[service.icon] || '✨'}</div>
              <h3 class="text-xl font-bold text-cream mb-2 group-hover:text-gold transition-colors">
                {service.title}
              </h3>
              <p class="text-cream/70 leading-relaxed text-sm">
                {service.description}
              </p>
            </div>

            {/* Decorative corner */}
            <div class="absolute top-0 right-0 w-16 h-16 bg-gold/10 rounded-bl-2xl rounded-tr-2xl transition-all duration-300 group-hover:bg-gold/20"></div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
