---
import business from '../../data/business.json';
import Button from '../ui/Button.astro';
import StarRating from '../ui/StarRating.astro';
import HeroBackground from '../effects/HeroBackground.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Three.js background (lazy-loaded via IntersectionObserver) -->
  <HeroBackground />

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Rating -->
    <div class="mb-6 flex items-center justify-center gap-3">
      <StarRating rating={business.rating} size="md" />
      <span class="text-cream/70 text-sm font-medium">
        {business.reviews_count} reseñas en Google Maps
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-cream mb-4 leading-tight">
      {business.name}
    </h1>

    <!-- Tagline -->
    <p class="text-xl md:text-2xl text-cream/80 font-light mb-8 max-w-2xl mx-auto">
      {business.tagline}
    </p>

    <!-- Category badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cream/10 backdrop-blur-sm text-cream/90 text-sm mb-10 border border-cream/20">
      <span class="w-2 h-2 rounded-full bg-gold"></span>
      {business.category} · {business.price_range}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href={`tel:${business.phone}`} variant="primary" size="lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Llamar ahora
      </Button>
      <Button href={business.google_maps_url} variant="outline" size="lg" class="border-cream/40 text-cream hover:bg-cream hover:text-coffee">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Cómo llegar
      </Button>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-cream/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
