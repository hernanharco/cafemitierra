---
import business from '../../data/business.json';
import BrandName from '../ui/BrandName.astro';
---

<footer class="bg-azul-dark text-cream/60 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <h3 class="text-2xl font-bold mb-3 font-serif"><BrandName variant="light" /></h3>
        <p class="text-cream/50 text-sm leading-relaxed">
          {business.tagline}
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-semibold text-cream mb-4">Enlaces</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#inicio" class="hover:text-rojo transition-colors">Inicio</a></li>
          <li><a href="#nosotros" class="hover:text-rojo transition-colors">Nosotros</a></li>
          <li><a href="#servicios" class="hover:text-rojo transition-colors">Servicios</a></li>
          <li><a href="#horarios" class="hover:text-rojo transition-colors">Horarios</a></li>
          <li><a href="#contacto" class="hover:text-rojo transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-cream mb-4">Contacto</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-rojo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {business.address.street}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-rojo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${business.phone}`} class="hover:text-rojo transition-colors">{business.phone}</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-cream/10 pt-8 mt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <p>© {new Date().getFullYear()} {business.name}. Todos los derechos reservados.</p>
      <div class="flex items-center gap-2 text-cream/40">
        <span>Hecho con</span>
        <svg class="w-4 h-4 text-rojo" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
        </svg>
        <span>en Avilés</span>
      </div>
    </div>
  </div>
</footer>
