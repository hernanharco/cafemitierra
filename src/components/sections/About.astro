---
import business from '../../data/business.json';
import ScrollReveal from '../effects/ScrollReveal.astro';
---

<section class="py-24 px-6 bg-cream">
  <div class="max-w-6xl mx-auto">
    <ScrollReveal>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Text -->
        <div>
          <span class="inline-block text-terracota font-semibold text-sm tracking-widest uppercase mb-4">
            Nuestra Historia
          </span>
          <h2 class="text-4xl md:text-5xl font-bold text-coffee mb-6 leading-tight">
            Un pedacito de <span class="text-terracota">Colombia</span> en Avilés
          </h2>
          <p class="text-coffee/70 text-lg leading-relaxed mb-6">
            {business.description}
          </p>
          <div class="flex flex-wrap gap-3">
            {business.features.map((feature) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-terracota/10 text-terracota text-sm font-medium">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {feature}
              </span>
            ))}
          </div>
        </div>

        <!-- Photo: Colombian coffee -->
        <div class="relative">
          <div class="aspect-square rounded-2xl overflow-hidden relative shadow-xl">
            <img
              src="/images/about-coffee.jpg"
              alt="Café colombiano recién preparado"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-coffee/40 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <span class="inline-block px-3 py-1 rounded-full bg-cream/90 text-coffee text-xs font-medium backdrop-blur-sm">
                ☕ Café colombiano de origen
              </span>
            </div>
          </div>
          <!-- Decorative rings -->
          <div class="absolute -top-4 -right-4 w-32 h-32 border-2 border-terracota/20 rounded-full -z-10"></div>
          <div class="absolute -bottom-4 -left-4 w-24 h-24 border-2 border-gold/20 rounded-full -z-10"></div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
